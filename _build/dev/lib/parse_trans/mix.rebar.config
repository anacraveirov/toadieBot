{minimum_otp_vsn,"21.0"}.
{erl_first_files,["src/parse_trans.erl","src/parse_trans_pp.erl",
                  "src/parse_trans_codegen.erl"]}.
{erl_opts,[debug_info]}.
{xref_checks,[undefined_function_calls]}.
{ex_doc,[{extras,["README.md","LICENSE"]},
         {main,"README.md"},
         {source_url,"https://github.com/uwiger/parse_trans"}]}.
{hex,[{doc,ex_doc}]}.
{profiles,
    [{doc,
         [{deps,[{edown,"0.9.1"}]},
          {edoc_opts,
              [{doclet,edown_doclet},
               {branch,"master"},
               {top_level_readme,
                   {"./README.md","http://github.com/uwiger/parse_trans",
                    "master"}}]}]},
     {test,[{extra_src_dirs,["examples"]}]}]}.
{overrides,[]}.
